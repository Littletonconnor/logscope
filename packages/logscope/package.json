{
  "name": "logscope",
  "version": "0.0.1",
  "description": "Zero-dependency, universal, library-first structured logging with scoped wide events.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Littletonconnor/logscope.git",
    "directory": "packages/logscope"
  },
  "keywords": [
    "logging",
    "logger",
    "structured-logging",
    "wide-events",
    "log",
    "zero-dependency",
    "typescript",
    "library-first",
    "scoped-logging",
    "universal"
  ],
  "author": "Connor Littleton",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "imports": {
    "#util": {
      "node": "./dist/util.node.js",
      "bun": "./dist/util.node.js",
      "deno": "./dist/util.deno.js",
      "browser": "./dist/util.js",
      "default": "./dist/util.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --build",
    "clean": "rm -rf dist",
    "test": "node --experimental-strip-types --experimental-transform-types --test 'src/**/*.test.ts'",
    "test:watch": "node --watch --experimental-strip-types --experimental-transform-types --test 'src/**/*.test.ts'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "tsdown": "^0.20.3"
  }
}
