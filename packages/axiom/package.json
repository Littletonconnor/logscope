{
  "name": "@logscope/axiom",
  "version": "0.0.1",
  "description": "Axiom sink adapter for logscope — send structured logs to Axiom.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Littletonconnor/logscope.git",
    "directory": "packages/axiom"
  },
  "keywords": [
    "logscope",
    "axiom",
    "logging",
    "structured-logging",
    "observability",
    "sink"
  ],
  "author": "Connor Littleton",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --build",
    "clean": "rm -rf dist",
    "test": "node --experimental-strip-types --experimental-transform-types --test 'src/**/*.test.ts'",
    "test:watch": "node --watch --experimental-strip-types --experimental-transform-types --test 'src/**/*.test.ts'",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "peerDependencies": {
    "logscope": "workspace:*"
  },
  "devDependencies": {
    "logscope": "workspace:*",
    "tsdown": "^0.20.3"
  }
}
